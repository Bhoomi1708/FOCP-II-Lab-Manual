/*Implement a solution to multiply two matrices of order m×n and p×q (if valid).*/
#include <iostream>
using namespace std;
int main() {
    int m, n;
    int p, q;
    cout << "Enter rows and columns of first matrix: ";
    cin >> m >> n;
    cout << "Enter rows and columns of second matrix: ";
    cin >> p >> q;
    if (n != p) {
        cout << "multiplication for this matrix is not possible.";
        return 0;
    }

    int a[m][n], b[p][q], c[m][q];

    cout << "Enter the elements of first matrix:\n";
    for (int i = 0; i < m; i++)
        for (int j = 0; j < n; j++)
            cin >> a[i][j];
    cout << "Enter the elements of second matrix:\n";
    for (int i = 0; i < p; i++)
        for (int j = 0; j < q; j++)
            cin >> b[i][j];
    for (int i = 0; i < m; i++)
        for (int j = 0; j < q; j++)
            c[i][j] = 0;
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < q; j++) {
            for (int k = 0; k < n; k++) {
                c[i][j] += a[i][k] * b[k][j];
            }
        }
    }
    cout << "Matrix Multiplication:\n";
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < q; j++)
            cout << c[i][j] << " ";
        cout << endl;
    }

    return 0;
}
